# pigOS Kernel Configuration
# Generated by make menuconfig

# ── Boot Options ────────────────────────────────────────
CONFIG_BOOT_SPLASH=y
CONFIG_BOOT_VERBOSE=y

# ── Drivers ─────────────────────────────────────────────
CONFIG_VGA_DRIVER=y
CONFIG_PS2_KEYBOARD=y
CONFIG_PS2_MOUSE=y

# ── Network Drivers ─────────────────────────────────────
CONFIG_NET_RTL8139=y
CONFIG_NET_E1000=y
CONFIG_NET_VIRTIO=y

# ── Network Stack (lwIP) ────────────────────────────────
CONFIG_LWIP=y
CONFIG_LWIP_TCP=y
CONFIG_LWIP_UDP=y
CONFIG_LWIP_ICMP=y
CONFIG_LWIP_DNS=y
CONFIG_LWIP_DHCP=y

# ── Filesystem ──────────────────────────────────────────
CONFIG_PIGFS=y
CONFIG_PIGFS_PERSIST=y

# ── Memory ──────────────────────────────────────────────
CONFIG_HEAP_ALLOC=y

# ── Crypto Subsystem ────────────────────────────────────
CONFIG_PIGSSL=y

# ── Init System (poing) ─────────────────────────────────
CONFIG_POING=y

# ── User Management ─────────────────────────────────────
CONFIG_USERS=y

# ── Shell (larpshell) ───────────────────────────────────
CONFIG_LARPSHELL=y

# ── Window Manager ──────────────────────────────────────
CONFIG_PIGWM=y

# ── Display Server ──────────────────────────────────────
CONFIG_VDM=y

# ── Logging ─────────────────────────────────────────────
CONFIG_PIGLOG=y
